+    else:
+        add("Promoter pledge ≤ 20%", pl > 20, f"pledged {pl:.0f}%")
+
+    # 3. Promoter stake < 40% OR falling > 3pp
+    prom, prom0 = m.get("prom_latest"), m.get("prom_early")
+    if prom is None:
